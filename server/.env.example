# ============================
# Server Configuration
# ============================
PORT=8080
NODE_ENV=production

# ============================
# CORS Configuration
# ============================
CORS_ALLOWED_ORIGINS=https://connectcards.live,http://connectcards.live,http://localhost:3000,http://msgcause-web.s3-website-us-west-2.amazonaws.com

# ============================
# Railway Public API URL
# (Used by frontend)
# ============================
PUBLIC_API_URL=https://msgcause-production.up.railway.app:8080

# ============================
# Database Configuration
# (Railway private network)
# ============================
PGHOST=postgres.railway.internal
PGPORT=5432
PGDATABASE=YOUR_DATABASE_NAME
PGUSER=YOUR_DATABASE_USER
PGPASSWORD=YOUR_DATABASE_PASSWORD
PGSSLMODE=disable

# ============================
# JWT / Auth
# ============================
JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=7d

# ============================
# Email / Notifications (optional)
# ============================
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# ============================
# AWS (optional if backend uploads files)
# ============================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2
AWS_S3_BUCKET=msgcause-web
